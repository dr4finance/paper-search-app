# Copy this to `.streamlit/secrets.toml` (LOCAL ONLY — gitignored)
# OR paste these key=value pairs into the Streamlit Cloud secrets editor.

GEMINI_API_KEY            = "your-gemini-api-key-here"
NCBI_EMAIL                = "your-email@example.com"
NCBI_API_KEY              = ""    # optional; raises PubMed rate limit
SPRINGER_API_KEY          = ""    # required for Springer Nature search
SEMANTIC_SCHOLAR_API_KEY  = ""    # optional; raises Semantic Scholar rate limit
